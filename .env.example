# =============================================================================
# Concert Ticket Booking System — environment configuration template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values:   cp .env.example .env
# `.env` is gitignored — NEVER commit real secrets.
#
# Where these are actually consumed:
#   - Local Kubernetes: shared values live in the `ticket-config` ConfigMap and the
#     `ticket-secret` Secret (infrastructure/k8s/00-namespace-config.yaml). Change the
#     SECRET values there for a real deployment.
#   - Running a service from the IDE / `./gradlew bootRun`: export these as env vars.
#   - Frontend: the VITE_* vars belong in `frontend/.env` (Vite only reads that).
#   - CI / code quality: SONAR_* are GitHub Actions secrets, not runtime env.
# Values below are the safe LOCAL-DEV defaults. 🔐 = secret, change for production.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres            # 🔐 lives in the `ticket-secret` Secret
# DB_URL is per-service (each service uses its own database). In k8s it is set per
# deployment; locally a service defaults to e.g.:
# DB_URL=jdbc:postgresql://localhost:5432/userdb   (userdb|eventdb|bookingdb|orderdb|paymentdb|ticketdb|admindb)

# --- Messaging (Apache Kafka) ------------------------------------------------
KAFKA_BROKERS=localhost:9092    # in-cluster: kafka:9092

# --- Cache / seat locks (Redis) ----------------------------------------------
REDIS_HOST=localhost            # in-cluster: redis
REDIS_PORT=6379

# --- Search (Elasticsearch) --------------------------------------------------
ELASTICSEARCH_URI=http://localhost:9200    # in-cluster: http://elasticsearch:9200

# --- Email (SMTP / MailHog locally) ------------------------------------------
MAIL_HOST=localhost             # in-cluster: mailhog
MAIL_PORT=1025

# --- Authentication (JWT, user-service) --------------------------------------
JWT_SECRET=dev-secret-change-me-please-at-least-32-bytes   # 🔐 HS256 signing key, >= 32 bytes; in `ticket-secret`
JWT_TTL_SECONDS=86400           # token lifetime (24h)

# --- Payment gateway (payment-service; demo gateway is simulated) ------------
PAYMENT_GATEWAY_URL=http://localhost:8090

# --- API gateway routing (only the Spring gateway uses these) ----------------
# Optional locally; nginx is the real entry point. In-cluster these point at the services.
USER_SERVICE_URL=http://localhost:8081
EVENT_SERVICE_URL=http://localhost:8082
SEARCH_SERVICE_URL=http://localhost:8083
BOOKING_SERVICE_URL=http://localhost:8084
ORDER_SERVICE_URL=http://localhost:8085
PAYMENT_SERVICE_URL=http://localhost:8086
TICKET_SERVICE_URL=http://localhost:8087
ADMIN_SERVICE_URL=http://localhost:8089

# --- Frontend (put these in frontend/.env, not here) -------------------------
VITE_API_BASE_URL=              # empty = same origin (proxy/nginx route /api)
VITE_WS_URL=/ws                 # booking-service STOMP endpoint
VITE_PROXY_TARGET=http://localhost   # dev-server proxy target (the nginx LB)

# --- CI / code quality (GitHub Actions secrets, NOT runtime env) -------------
SONAR_TOKEN=                    # 🔐 GitHub repo secret for SonarQube Cloud analysis
# Also set (non-secret) project/org keys in backend/build.gradle and
# frontend/sonar-project.properties — see docs/sonarcloud-setup.md.
